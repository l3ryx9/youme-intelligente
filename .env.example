# =============================================================================
# YouMe Intelligente — Configuration des Variables d'Environnement
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE JAMAIS committer le fichier .env sur GitHub.

# -----------------------------------------------------------------------------
# Firebase — Configuration (obligatoire)
# Créez un projet sur https://console.firebase.google.com
# Activez : Authentication (Email/Password), Firestore, Cloud Messaging
# -----------------------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Google Gemini API — Module expérimental d'analyse des incohérences
# Gratuit jusqu'à 15 req/min sur https://aistudio.google.com
# Laissez vide pour désactiver le module Gemini
# -----------------------------------------------------------------------------
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
EXPO_PUBLIC_GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# hCaptcha — CAPTCHA pour inscription et connexion
# Gratuit sur https://dashboard.hcaptcha.com
# -----------------------------------------------------------------------------
EXPO_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# -----------------------------------------------------------------------------
# Configuration IA locale — Chemins des modèles
# Les modèles ne sont PAS inclus dans le dépôt (trop volumineux).
# Voir README.md section "Installation des modèles IA" pour les instructions.
# -----------------------------------------------------------------------------

# Whisper Tiny ONNX (transcription vocale)
# Télécharger depuis: https://huggingface.co/onnx-community/whisper-tiny
EXPO_PUBLIC_WHISPER_MODEL_PATH=./models/whisper-tiny.onnx

# DistilBERT Emotion (analyse émotionnelle)
# Télécharger depuis: https://huggingface.co/bhadresh-savani/distilbert-base-uncased-emotion
EXPO_PUBLIC_EMOTION_MODEL_PATH=./models/emotion-distilbert.onnx

# LLM léger — Gemma 2B quantifié (analyse sémantique)
# Télécharger depuis: https://huggingface.co/google/gemma-2b-it (version GGUF Q4)
EXPO_PUBLIC_LLM_MODEL_PATH=./models/gemma-2b-it-q4.gguf

# -----------------------------------------------------------------------------
# Configuration générale de l'application
# -----------------------------------------------------------------------------
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=YouMe Intelligente
EXPO_PUBLIC_APP_VERSION=1.0.0

# Délai (ms) avant de lancer l'analyse IA après réception d'un message
EXPO_PUBLIC_AI_ANALYSIS_DELAY_MS=2000

# Activer/désactiver l'IA par défaut au premier lancement
EXPO_PUBLIC_AI_ENABLED_DEFAULT=true

# Seuil de score de cohérence en dessous duquel une alerte est affichée (0-100)
EXPO_PUBLIC_INCONSISTENCY_THRESHOLD=70

# Nombre minimum d'incohérences pour déclencher l'analyse Gemini avancée
EXPO_PUBLIC_GEMINI_TRIGGER_COUNT=3
